# Copy to .env:  cp .env.example .env

# Database (pick one profile)

# Local PostgreSQL
DB_URL=postgresql://USER:PASSWORD@localhost:5432/db
DB_SSL=false

# Neon (production / cloud)
# DB_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
# DB_SSL=true

# Auth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# OAuth (required for login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# Dev-only: set to true to access /admin and admin actions without logging in
# or setting role = 1 in the DB. Ignored when NODE_ENV=production.
ADMIN_DEV_BYPASS=false
